                  <a href="https://policies.google.com/technologies/partner-sites?hl=ja" target="_blank" rel="noopener noreferrer">https://policies.google.com/technologies/partner-sites?hl=ja</a>
                </p>
              </div>
            </li>
            <li>
              <span class="lm">(2)</span>
