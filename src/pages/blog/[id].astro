---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getBlogList, getBlog, formatNewsDate, pickCategory, type Blog } from '../../lib/microcms';

export async function getStaticPaths() {
  const list = await getBlogList(100);
  return list
    .filter((item) => !item.externalUrl)
    .map((item) => ({
      params: { id: item.id },
      props: { blog: item },
    }));
}

interface Props {
  blog: Blog;
}

const { blog } = Astro.props;
const full = (await getBlog(blog.id)) ?? blog;

const category = pickCategory(full.category);
const date = formatNewsDate(full.publishedDate || full.publishedAt);

const pageTitle = `${full.title} | YUTECT Blog`;
const description = full.excerpt || `${full.title} - YUTECTのブログ記事`;
---

<Layout title={pageTitle} description={description}>
  <Nav />

  <article class="news-detail">
    <div class="shell">
      <div class="news-detail-inner">
        <a href="/#news" class="back-link">Back to News</a>

        <div class="news-detail-meta">
          {date && <div class="news-date">{date}</div>}
          {category && <span class="news-tag">{category}</span>}
        </div>

        <h1>{full.title}</h1>

        {full.thumbnail && (
          <div class="news-detail-thumb">
            <img src={full.thumbnail.url} alt={full.title} width={full.thumbnail.width} height={full.thumbnail.height} />
          </div>
        )}

        {full.body ? (
          <div class="news-body" set:html={full.body}></div>
        ) : (
          <div class="news-body"><p>本文はまだありません。</p></div>
        )}
      </div>
    </div>
  </article>

  <Footer />
</Layout>
