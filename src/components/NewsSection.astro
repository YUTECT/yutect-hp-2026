---
import NewsCard from './NewsCard.astro';
import { getMergedFeed, type FeedItem } from '../lib/microcms';

const HIGHLIGHT_COUNT = 4;
// Fetch slightly more than we display so we can tell whether a full list page is warranted.
const items: FeedItem[] = await getMergedFeed(HIGHLIGHT_COUNT, 20);
const all: FeedItem[] = await getMergedFeed(100, 100);
const hasMore = all.length > HIGHLIGHT_COUNT;
const gridClass = `news-grid news-grid-${Math.min(items.length, 4) || 4}`;
---

<section id="news" class="news-section">
  <div class="shell">
    <div class="section-head-c">
      <span class="eyebrow">News &amp; Column</span>
      <h2>ニュース＆コラム</h2>
      <p>Revit助人および建築×AIに関する最新のお知らせをお届けします。</p>
    </div>

    <div class={gridClass}>
      {items.length === 0 && (
        <div class="news-empty">記事はまだありません。</div>
      )}
      {items.map((item) => <NewsCard item={item} />)}
    </div>

    {hasMore && (
      <div class="news-section-more-wrap">
        <a href="/news/" class="news-section-more">すべての記事を見る <span aria-hidden="true">→</span></a>
      </div>
    )}
  </div>
</section>
