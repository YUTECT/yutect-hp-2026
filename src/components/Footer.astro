---
import { CONTACT_FORM_URL } from '../lib/config';

const serviceLinks = [
  { href: '/#features', label: 'Revit助人' },
  { href: '/#services', label: 'AI開発・コンサルティング' },
];
const companyLinks = [
  { href: '/#company', label: '会社概要' },
  { href: '/#news', label: 'ニュース' },
];
const contactLinks = [
  { href: CONTACT_FORM_URL, label: 'お問い合わせ', external: true },
];
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <img src="/assets/yutect-logo.png" alt="YUTECT" />
      <p>建築の未来を、テクノロジーで設計する。<br />YUTECTは、AIと建築の境界を再設計する企業です。</p>
    </div>
    <div class="footer-col">
      <h5>Services</h5>
      <ul>
        {serviceLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
      </ul>
    </div>
    <div class="footer-col">
      <h5>Company</h5>
      <ul>
        {companyLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
      </ul>
    </div>
    <div class="footer-col">
      <h5>Contact</h5>
      <ul>
        {contactLinks.map((link) => (
          <li>
            {link.external ? (
              <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
            ) : (
              <a href={link.href}>{link.label}</a>
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© 2026 YUTECT inc.</span>
    <span>Architectural Innovation, refined.</span>
  </div>
</footer>
