---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Revit助人 — Revitの自動設計AIアドイン | YUTECT',
  description = 'YUTECTは建築×AIで設計プロセスを再設計します。主力プロダクト「Revit助人」は、自然言語でRevitを操作する設計AIアドインです。',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600;700;800&display=swap" />
</head>
<body>
  <slot />
</body>
</html>
